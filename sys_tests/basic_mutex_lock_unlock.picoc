// in:
// expected:42 84

#include "../lib/mutex/mutex.h"
#include "../lib/mutex/mutex.picoc"

int main() {
    struct mutex m;

    mutex_init(&m);

    debug;
    mutex_lock(&m);
    debug;
    print(42);
    mutex_unlock(&m);
    debug;

    m.lock = 1;
    mutex_lock(&m);
    debug;
    print(84);
    mutex_unlock(&m);
    debug;

    return 0;
}

// in:42 X 99 42 X 99
// expected:42X99  42 X 99
// dependencies: ../lib/stdio/stdio.picoc

#include "../lib/stdio/stdio.h"

int main() {
    int a;
    int b;
    int c;

    scanf("%d%c%d", &a, &b, &c);
    printf("%d%c%d", a, b, c);

    scanf(" %d %c %d", &a, &b, &c);
    printf(" %d %c %d", a, b, c);

    return 0;
}
